#!/usr/bin/env bash
set -eu

#######################################
# 参数:
#   $1: ROOT_DIR
#######################################

sh -c "$(curl -fsSL https://git.io/zinit-install)"
cat $1/config/zsh/zinit-pluginsAndTheme.txt >> ~/.zshrc
sed -i "1d" ~/.zshrc
echo ''; color_print info 'powerlevel10kの設定が終わったら、exitを入力してください。'; echo ''
sleep 3
exec $SHELL -l
#zinit self-update
