################################
# App Lifecycle
################################
confirm-close-surface = false
quit-after-last-window-closed = true

################################
# Window / Appearance
################################
theme = Iceberg Dark
window-theme = ghostty
macos-titlebar-style = transparent

window-padding-balance = true
window-padding-x = 0
window-padding-y = 0

background-opacity = 0.65
background-blur = macos-glass-clear
background-blur-radius = 20

################################
# Terminal Behavior
################################
scrollback-limit = 10000000
shell-integration-features = ssh-env

################################
# Font / Typography
################################
font-family = MesloLGMDZ Nerd Font Mono, Hei, YuGothic
font-style = Regular
font-size = 14

################################
# Input / Interaction
################################
mouse-hide-while-typing = true
copy-on-select = false

################################
# Override the native 'edit config' shortcut with the CLI action, respecting ${VISUAL:-${EDITOR}}
#   1. `\x1bq` runs the zsh `push-line-or-edit` widget (bound to alt-q)
#   2. `ghostty +edit-config` is sent to the shell prompt
#   3. `\x0d` enters/executes the command currently on the prompt
keybind = unconsumed:super+,=text:\x1bqghostty +edit-config\x0d

